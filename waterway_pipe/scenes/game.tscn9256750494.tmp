script/source = "class_name Level extends Node

## Сигналы
signal level_complete(success: bool, time: float, moves: int)
signal water_reached_end()
signal update_timer(seconds: int)
signal update_moves(count: int)

# Настройки
@export var grid_size: Vector2i = Vector2i(6, 8)
@export var cell_size: int = 100
@export var level_data: Dictionary = {}

# Ссылки
@onready var grid_container: Node2D = $GridContainer
@onready var pipe_scene: PackedScene = preload(\"res://scenes/pipes/pipe.tscn\")

# Состояние
var pipes: Dictionary = {}
var start_pipe: Pipe
var end_pipe: Pipe
var elapsed_time: float = 0.0
var move_count: int = 0
var is_playing: bool = false
var is_completed: bool = false

func _ready() -> void:
	print(\"=== ДИАГНОСТИКА LEVEL ===\")
	print(\"1. Имя текущего узла: \", name)
	print(\"2. Тип текущего узла: \", get_class())
	print(\"3. Дочерние узлы: \", get_children())
	print(\"4. Есть ли GridContainer? \", has_node(\"GridContainer\"))
	
	if grid_container == null:
		push_error(\"КРИТИЧЕСКАЯ ОШИБКА: grid_container == null!\")
		print(\"💡 РЕШЕНИЕ: Убедитесь, что GridContainer является прямым потомком узла, на котором висит этот скрипт.\")
		return
	
	print(\"5. grid_container найден успешно!\")
	_create_grid()
	
	if not level_data.is_empty():
		load_level(level_data)

func _process(delta: float) -> void:
	if is_playing and not is_completed:
		elapsed_time += delta
		if int(elapsed_time) != int(elapsed_time - delta):
			update_timer.emit(int(elapsed_time))

func _create_grid() -> void:
	for y in grid_size.y:
		for x in grid_size.x:
			var pos = Vector2i(x, y)
			var pipe = pipe_scene.instantiate()
			pipe.grid_position = pos
			pipe.pipe_type = Pipe.PipeType.EMPTY
			pipe.position = _grid_to_world(pos)
			pipe.pipe_rotated.connect(_on_pipe_rotated)
			grid_container.add_child(pipe)
			pipes[pos] = pipe

func _grid_to_world(grid_pos: Vector2i) -> Vector2:
	var offset = Vector2(cell_size, cell_size) * 0.5
	return Vector2(grid_pos) * cell_size + offset

func load_level(data: Dictionary) -> void:
	level_data = data
	
	if data.has(\"grid_size\"):
		grid_size = data.grid_size
	
	for pipe in pipes.values():
		pipe.queue_free()
	pipes.clear()
	_create_grid()
	
	if data.has(\"pipes\"):
		for pos_str in data.pipes:
			var pos = _str_to_vec(pos_str)
			if pipes.has(pos):
				var pipe_data = data.pipes[pos_str]
				pipes[pos].pipe_type = pipe_data.type
				pipes[pos].rotation_state = pipe_data.get(\"rotation\", 0)
				pipes[pos].rotation_degrees = pipes[pos].rotation_state * 90
				pipes[pos].is_locked = pipe_data.get(\"locked\", false)
				pipes[pos]._update_visuals()
				
				if pipes[pos].pipe_type == Pipe.PipeType.START:
					start_pipe = pipes[pos]
				elif pipes[pos].pipe_type == Pipe.PipeType.END:
					end_pipe = pipes[pos]
	
	reset_level()

func reset_level() -> void:
	for pipe in pipes.values():
		pipe.reset_fill()
	elapsed_time = 0.0
	move_count = 0
	is_completed = false
	is_playing = true
	update_moves.emit(0)

func _on_pipe_rotated(pipe: Pipe) -> void:
	if is_completed:
		return
	move_count += 1
	update_moves.emit(move_count)
	_check_connections()

func _check_connections() -> void:
	for pipe in pipes.values():
		pipe.reset_fill()
	
	if start_pipe == null:
		return
	
	var visited: Dictionary = {}
	var queue: Array = [start_pipe]
	visited[start_pipe.grid_position] = true
	start_pipe.fill_with_water()
	
	var reached_end: bool = false
	
	while queue.size() > 0:
		var current: Pipe = queue.pop_front()
		
		if current == end_pipe:
			reached_end = true
			break
		
		for side in current.get_active_sides():
			var neighbor_pos = _get_neighbor_pos(current.grid_position, side)
			
			if not pipes.has(neighbor_pos):
				continue
			if visited.has(neighbor_pos):
				continue
			
			var neighbor: Pipe = pipes[neighbor_pos]
			var opposite_side = Pipe.get_opposite_side(side)
			
			if current.has_connection_to(side) and neighbor.has_connection_to(opposite_side):
				visited[neighbor_pos] = true
				neighbor.fill_with_water()
				queue.append(neighbor)
	
	if reached_end and not is_completed:
		is_completed = true
		is_playing = false
		water_reached_end.emit()
		await get_tree().create_timer(1.0).timeout
		level_complete.emit(true, elapsed_time, move_count)

func _get_neighbor_pos(pos: Vector2i, side: int) -> Vector2i:
	match side:
		Pipe.Side.TOP:
			return pos + Vector2i(0, -1)
		Pipe.Side.RIGHT:
			return pos + Vector2i(1, 0)
		Pipe.Side.BOTTOM:
			return pos + Vector2i(0, 1)
		Pipe.Side.LEFT:
			return pos + Vector2i(-1, 0)
	return pos

func _str_to_vec(s: String) -> Vector2i:
	var parts = s.split(\",\")
	return Vector2i(parts[0].to_int(), parts[1].to_int())

func handle_tap(world_pos: Vector2) -> void:
	if is_completed:
		return
	
	for pipe in pipes.values():
		if pipe.pipe_type == Pipe.PipeType.EMPTY:
			continue
		
		var local_pos = pipe.to_local(world_pos)
		var rect = Rect2(-cell_size/2, -cell_size/2, cell_size, cell_size)
		
		if rect.has_point(local_pos):
			pipe.rotate_pipe()
			return
